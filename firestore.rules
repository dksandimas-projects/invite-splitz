rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the authenticated user owns this wedding
    function isOwner(weddingId) {
      return request.auth != null &&
        request.auth.uid == get(/databases/$(database)/documents/weddings/$(weddingId)).data.ownerId;
    }

    // Helper: check if the authenticated user is the owner or an authorized email
    function isAuthorized(weddingId) {
      return request.auth != null && (
        request.auth.uid == get(/databases/$(database)/documents/weddings/$(weddingId)).data.ownerId ||
        (request.auth.token.email != null && request.auth.token.email in get(/databases/$(database)/documents/weddings/$(weddingId)/private/access).data.authorizedEmails)
      );
    }

    // Wedding config — public read, owner/team write
    match /weddings/{weddingId} {
      allow read: if true;
      allow write: if isAuthorized(weddingId);
    }

    // Private subcollection — authenticated read, owner/team write
    // Any signed-in user can read (needed for AuthGuard email check after sign-in)
    // Only authorized team members can update the authorized emails list
    match /weddings/{weddingId}/private/{docId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized(weddingId);
    }

    // Guest records
    match /weddings/{weddingId}/guests/{guestId} {

      // Public: read a single guest by token (used by the guest site via
      // getGuestByToken and the RSVP API route).
      allow get: if true;

      // List: enforced client-side. We tried tightening to
      //   `isOwner(weddingId) || <query-on-token>` but the Firestore rules
      //   engine doesn't evaluate `request.query.where[0].field` reliably
      //   across versions, and the documented `request.query.whereFields()`
      //   helper isn't available. The token entropy (31^12 ≈ 8.2e17
      //   combinations) is the enumeration guard. Move token resolution
      //   to a Cloud Function if/when this becomes a concern.
      allow list: if true;

      // Public: submit RSVP — only rsvpCount and rsvpSubmittedAt fields,
      // only if rsvpCount is currently null (first submission only)
      allow update: if
        request.auth == null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["rsvpCount", "rsvpSubmittedAt"]) &&
        resource.data.rsvpCount == null &&
        request.resource.data.rsvpCount is int &&
        request.resource.data.rsvpCount >= 0 &&
        request.resource.data.rsvpCount <= resource.data.pax;

      // Owner/Team: full read/write (dashboard)
      allow read, write: if isAuthorized(weddingId);
    }
  }
}
